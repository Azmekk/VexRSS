# Copy this file to `docker-compose.yml` and run `docker compose up -d`.
# The local copy is gitignored so your changes stay local.

services:
  vexrss:
    image: ghcr.io/azmekk/vexrss:latest

    # Or build locally from a cloned repo:
    # build:
    #   context: .
    #   dockerfile: Dockerfile

    container_name: vexrss
    restart: unless-stopped

    ports:
      # Host:container. Change the host side if :8080 is taken.
      - "8080:8080"

    volumes:
      # Persists the SQLite database across container rebuilds.
      - ./data:/data

    # Optional — the defaults below are already applied. Uncomment to tweak.
    # command:
    #   - "-addr=:8080"
    #   - "-db=/data/vexrss.db"
    #   - "-poll=15m"       # how often feeds are refreshed
    #   - "-log=info"       # debug | info | warn | error
